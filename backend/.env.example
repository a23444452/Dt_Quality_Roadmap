DATABASE_URL=sqlite:///./dev.db
JWT_SECRET=change-me-to-random-64-chars
JWT_EXPIRY_HOURS=8
CORS_ORIGINS=http://localhost:5173

# 前端網址 (用於 Email 中的連結)
APP_BASE_URL=http://localhost:5173

# Email 通知設定
# Corning 內部網路：留空 SMTP_HOST 即可自動使用 smtphub.corning.com
# 外部網路：需設定完整 SMTP 參數
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=DtRoadmap@corning.com

# Gunicorn 生產環境設定 (選填，有預設值)
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
